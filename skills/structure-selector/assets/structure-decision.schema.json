{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structure decision",
  "type": "object",
  "required": [
    "primary_user",
    "primary_task",
    "dominant_grammar",
    "organizing_key",
    "content_sequence",
    "navigation",
    "responsive_reflow",
    "growth_test",
    "rejected_patterns",
    "unknowns"
  ],
  "properties": {
    "primary_user": {
      "type": "string",
      "minLength": 1
    },
    "primary_task": {
      "type": "string",
      "minLength": 1
    },
    "dominant_grammar": {
      "enum": [
        "identity-profile",
        "chronological-ledger",
        "writing-index",
        "portfolio-index",
        "product-service",
        "collection-catalog",
        "institution-information",
        "task-workflow",
        "justified-hybrid"
      ]
    },
    "organizing_key": {
      "type": "string",
      "minLength": 1
    },
    "content_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "navigation": {
      "type": "object",
      "required": [
        "mode",
        "items"
      ],
      "properties": {
        "mode": {
          "enum": [
            "none",
            "linear",
            "anchor",
            "global",
            "filter",
            "mixed"
          ]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "responsive_reflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "growth_test": {
      "type": "string",
      "minLength": 1
    },
    "rejected_patterns": {
      "type": "array",
      "minItems": 2
    },
    "hybrid_justification": {
      "type": [
        "string",
        "null"
      ]
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
