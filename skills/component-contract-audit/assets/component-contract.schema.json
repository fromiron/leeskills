{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "leeskills component contract audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "component",
    "purpose",
    "primary_user_task",
    "source_of_truth",
    "evidence",
    "anatomy",
    "variants",
    "states",
    "responsive_behavior",
    "content_rules",
    "accessibility",
    "token_mappings",
    "parity",
    "exceptions",
    "findings",
    "accepted_risks",
    "unknowns"
  ],
  "properties": {
    "component": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "primary_user_task": {
      "type": "string",
      "minLength": 1
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "location",
        "owner",
        "change_process"
      ],
      "properties": {
        "surface": {
          "enum": [
            "design",
            "documentation",
            "code",
            "live",
            "split"
          ]
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "change_process": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface",
          "location",
          "evidence_state",
          "notes"
        ],
        "properties": {
          "surface": {
            "enum": [
              "design",
              "documentation",
              "code",
              "test",
              "live",
              "research"
            ]
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "anatomy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "requirement",
          "role",
          "evidence_state"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "requirement": {
            "enum": [
              "required",
              "optional",
              "conditional"
            ]
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "required",
          "status",
          "evidence_state"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "unknown",
              "not-applicable"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "applicable",
          "status",
          "visual",
          "behavior",
          "accessibility",
          "evidence_state"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "applicable": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "unknown",
              "not-applicable"
            ]
          },
          "visual": {
            "type": "string"
          },
          "behavior": {
            "type": "string"
          },
          "accessibility": {
            "type": "string"
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "responsive_behavior": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "condition",
          "change",
          "preserved_information",
          "required",
          "status",
          "evidence_state"
        ],
        "properties": {
          "condition": {
            "type": "string",
            "minLength": 1
          },
          "change": {
            "type": "string",
            "minLength": 1
          },
          "preserved_information": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "unknown",
              "not-applicable"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "content_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule",
          "reason",
          "required",
          "status",
          "evidence_state"
        ],
        "properties": {
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "unknown",
              "not-applicable"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "accessibility": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check",
          "required",
          "status",
          "evidence_state",
          "evidence"
        ],
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "unknown",
              "not-applicable"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "token_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "token",
          "surface",
          "evidence_state"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "token": {
            "type": "string",
            "minLength": 1
          },
          "surface": {
            "enum": [
              "design",
              "documentation",
              "code",
              "live",
              "shared"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "parity": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface",
          "required",
          "status",
          "evidence"
        ],
        "properties": {
          "surface": {
            "enum": [
              "design",
              "documentation",
              "code",
              "live"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "aligned",
              "drift",
              "unknown",
              "not-inspected"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision",
          "reason",
          "identity_or_task_value",
          "owner",
          "review_trigger",
          "status",
          "evidence_state"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "identity_or_task_value": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "review_trigger": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "proposed",
              "accepted",
              "rejected",
              "unknown"
            ]
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "location",
          "problem",
          "impact",
          "smallest_change",
          "verification",
          "owner",
          "evidence_state",
          "confidence"
        ],
        "properties": {
          "severity": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "problem": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "smallest_change": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "evidence_state": {
            "enum": [
              "observed",
              "measured",
              "inferred",
              "unknown"
            ]
          },
          "confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "accepted_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
